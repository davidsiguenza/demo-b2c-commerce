{
    "name": "b2c-catalog-onboarding-bff",
    "version": "0.1.0",
    "private": true,
    "description": "BFF that turns a CSV/ZIP into a B2C Commerce catalog import — extract, validate, preview, repackage as site-archive, WebDAV PUT, trigger sfcc-site-archive-import, then SearchReindex.",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "start": "tsx src/index.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@hono/node-server": "^1.13.7",
        "archiver": "^8.0.0",
        "csv-parse": "^7.0.0",
        "dotenv": "^17.4.2",
        "fast-xml-parser": "^4.5.0",
        "hono": "^4.6.13",
        "yauzl-promise": "^4.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/archiver": "^8.0.0",
        "@types/node": "^22.10.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    }
}
