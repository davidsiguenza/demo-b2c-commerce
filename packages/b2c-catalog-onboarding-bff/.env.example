# --- Sandbox identity ---
B2C_INSTANCE_HOST=__sandbox__.dx.commercecloud.salesforce.com
B2C_TENANT=__sandbox_with_underscores__
B2C_ORG_ID=f_ecom___sandbox_with_underscores__
B2C_SHORT_CODE=__8char_realm_short_code__

# --- Catalogs / pricebooks / inventory of the storefront ---
# The storefront master catalog (cross-publish target), the pricebook the site
# uses, and the inventory list the site uses. Find these in BM → Merchant Tools.
STOREFRONT_CATALOG_ID=__storefront_catalog_id__
DEFAULT_PRICEBOOK_ID=__site_pricebook_id__
DEFAULT_INVENTORY_LIST_ID=__site_inventory_list_id__
# Units stocked per product when the source upload doesn't include inventory XML
DEFAULT_INVENTORY_UNITS=10

# --- Account Manager OAuth2 (client_credentials) ---
# Create at https://account.demandware.com → API Client.
# Required scope: SALESFORCE_COMMERCE_API:<tenant>
AM_CLIENT_ID=__your_am_client_uuid__
AM_CLIENT_SECRET=__your_am_client_secret__

# --- WebDAV (Impex) ---
# Your BM username and the per-user WebDAV password set in BM
# (Administration → Organization → Users → <user> → WebDAV Access).
WEBDAV_USER=__your_bm_user_email__
WEBDAV_PASSWORD=__your_webdav_password__

# --- Reindex ---
# Job ID (Administration → Operations → Jobs in BM) for SearchReindex.
# When set, the import flow triggers it so the storefront picks up changes in
# seconds. Leave empty to fall back to SFCC's scheduled delta-index.
REINDEX_JOB_ID=

# --- Server ---
PORT=3001
