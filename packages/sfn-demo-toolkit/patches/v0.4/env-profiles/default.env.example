# ============================================================================
# Profile template — copy to .env.profiles/<client-id>.env and fill in values.
# Then run: pnpm demo:switch <client-id>
# ============================================================================

# Active branding client (must match a folder in src/extensions/branding/clients/)
PUBLIC__app__global__branding__activeClient=default

# ============================================================================
# Managed Runtime (only needed for `pnpm push` deploys)
# ============================================================================
MRT_PROJECT=
MRT_TARGET=

# ============================================================================
# Commerce Cloud SCAPI (REQUIRED)
# ============================================================================
PUBLIC__app__commerce__api__clientId=
PUBLIC__app__commerce__api__organizationId=
PUBLIC__app__commerce__api__shortCode=
PUBLIC__app__commerce__api__privateKeyEnabled=true
COMMERCE_API_SLAS_SECRET=

# ============================================================================
# Site config
# ============================================================================
PUBLIC__app__defaultSiteId=
PUBLIC__app__commerce__sites='[
  {
    "id": "REPLACE_ME",
    "defaultLocale": "en-GB",
    "defaultCurrency": "GBP",
    "supportedLocales": [
      {"id": "en-GB", "preferredCurrency": "GBP"}
    ],
    "supportedCurrencies": ["GBP"]
  }
]'
